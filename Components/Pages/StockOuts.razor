@page "/stock-outs"
@inherits LocalizedComponentBase
@inject MovementService MovementService
@inject ISnackbar Snackbar

<PageTitle>@L["nav.stockOuts"] - StockDemo Admin</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["stockOuts.title"]</MudText>

<MudPaper Elevation="1">
    <MudTable Items="Filtered" Loading="_loading" Hover="true" Striped="true">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="@L["movements.searchHint"]" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
            <MudSpacer />
            <MudDateRangePicker @bind-DateRange="_range" Label="@L["common.dateRange"]" Clearable="true"
                                Class="mt-0" Style="max-width: 320px;" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["movements.code"]</MudTh>
            <MudTh>@L["common.product"]</MudTh>
            <MudTh>@L["common.location"]</MudTh>
            <MudTh Style="text-align:right">@L["common.quantity"]</MudTh>
            <MudTh>@L["common.createdBy"]</MudTh>
            <MudTh>@L["common.date"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["movements.code"]">@context.StockOutCode</MudTd>
            <MudTd DataLabel="@L["common.product"]">@(context.Product?.ProductName ?? $"#{context.ProductId}")</MudTd>
            <MudTd DataLabel="@L["common.location"]">@(context.Location?.LocationName ?? $"#{context.LocationId}")</MudTd>
            <MudTd DataLabel="@L["common.quantity"]" Style="text-align:right">
                <MudChip T="string" Color="Color.Error" Size="Size.Small">-@context.Quantity</MudChip>
            </MudTd>
            <MudTd DataLabel="@L["common.createdBy"]">@(context.User?.FullName ?? $"#{context.CreatedBy}")</MudTd>
            <MudTd DataLabel="@L["common.date"]">@context.CreatedDate.ToString("dd/MM/yyyy HH:mm")</MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText Class="pa-4">@L["stockOuts.none"]</MudText></NoRecordsContent>
        <PagerContent><MudTablePager RowsPerPageString="@L["common.rowsPerPage"]" /></PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<StockOutDto> _items = new();
    private string _search = string.Empty;
    private DateRange? _range;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var result = await MovementService.GetStockOutsAsync();
        if (result.Success) _items = result.Data ?? new();
        else Snackbar.Add(result.Message ?? "Error", Severity.Error);
        _loading = false;
    }

    private IEnumerable<StockOutDto> Filtered => _items.Where(Match);

    private bool Match(StockOutDto x)
    {
        if (_range?.Start is { } start && x.CreatedDate.Date < start.Date) return false;
        if (_range?.End is { } end && x.CreatedDate.Date > end.Date) return false;
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var s = _search.Trim();
        return (x.Product?.ProductName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
            || (x.StockOutCode?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false)
            || (x.Location?.LocationName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false);
    }
}
