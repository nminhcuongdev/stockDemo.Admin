@page "/"
@inherits LocalizedComponentBase
@inject DashboardService DashboardService

<PageTitle>@L["dashboard.title"] - StockDemo Admin</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["dashboard.title"]</MudText>

@if (_loading)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-4" />
}
else
{
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="@L["dashboard.products"]" Value="@_stats.ProductCount.ToString()"
                      Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="@L["dashboard.locations"]" Value="@_stats.LocationCount.ToString()"
                      Icon="@Icons.Material.Filled.Place" Color="Color.Info" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="@L["dashboard.totalQty"]" Value="@_stats.TotalQuantity.ToString("N0")"
                      Icon="@Icons.Material.Filled.Warehouse" Color="Color.Success" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <StatCard Title="@L["dashboard.lowStockCount"]" Value="@_stats.LowStockCount.ToString()"
                      Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
        </MudItem>
    </MudGrid>

    <MudText Typo="Typo.h6" Class="mt-8 mb-2">@L["dashboard.belowMin"]</MudText>
    <MudPaper Elevation="1">
        <MudTable Items="_lowStock" Dense="true" Hover="true" Striped="true">
            <HeaderContent>
                <MudTh>@L["products.codeShort"]</MudTh>
                <MudTh>@L["products.name"]</MudTh>
                <MudTh Style="text-align:right">@L["lowStock.current"]</MudTh>
                <MudTh Style="text-align:right">@L["lowStock.min"]</MudTh>
                <MudTh Style="text-align:right">@L["lowStock.shortage"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Mã SP">@context.Product?.ProductCode</MudTd>
                <MudTd DataLabel="Tên sản phẩm">@context.Product?.ProductName</MudTd>
                <MudTd DataLabel="Tồn hiện tại" Style="text-align:right">@context.CurrentQuantity</MudTd>
                <MudTd DataLabel="Định mức tối thiểu" Style="text-align:right">@context.MinQuantity</MudTd>
                <MudTd DataLabel="Thiếu hụt" Style="text-align:right">
                    <MudChip T="string" Color="Color.Error" Size="Size.Small">@context.Shortage</MudChip>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                <MudText Class="pa-4">@L["dashboard.noLowStock"]</MudText>
            </NoRecordsContent>
        </MudTable>
    </MudPaper>
}

@code {
    private bool _loading = true;
    private DashboardStats _stats = new(0, 0, 0, 0);
    private List<LowStockItemDto> _lowStock = new();

    protected override async Task OnInitializedAsync()
    {
        _stats = await DashboardService.GetStatsAsync();
        var low = await DashboardService.GetLowStockAsync();
        _lowStock = low.Data ?? new();
        _loading = false;
    }
}
