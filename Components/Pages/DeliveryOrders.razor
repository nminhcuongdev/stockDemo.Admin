@page "/delivery-orders"
@inherits LocalizedComponentBase
@inject DeliveryOrderService DeliveryOrderService
@inject ISnackbar Snackbar

<PageTitle>@L["delivery.title"] - StockDemo Admin</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["delivery.title"]</MudText>

<MudPaper Elevation="1">
    <MudTable Items="_items" Loading="_loading" Hover="true" Striped="true" Filter="Filter">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="@L["delivery.searchHint"]" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["delivery.poNumber"]</MudTh>
            <MudTh>@L["common.product"]</MudTh>
            <MudTh Style="text-align:right">@L["common.quantity"]</MudTh>
            <MudTh>@L["delivery.deliveryDate"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["delivery.poNumber"]">@context.PONumber</MudTd>
            <MudTd DataLabel="@L["common.product"]">@(context.Product?.ProductName ?? $"#{context.ProductId}")</MudTd>
            <MudTd DataLabel="@L["common.quantity"]" Style="text-align:right">@context.Quantity</MudTd>
            <MudTd DataLabel="@L["delivery.deliveryDate"]">@context.DeliveryDate.ToString("dd/MM/yyyy")</MudTd>
            <MudTd DataLabel="@L["common.status"]">
                <MudChip T="string" Size="Size.Small" Color="@StatusColor(context.Status)">@context.Status</MudChip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText Class="pa-4">@L["delivery.none"]</MudText></NoRecordsContent>
        <PagerContent><MudTablePager RowsPerPageString="@L["common.rowsPerPage"]" /></PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<DeliveryOrderDto> _items = new();
    private string _search = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var result = await DeliveryOrderService.GetAllAsync();
        if (result.Success) _items = result.Data ?? new();
        else Snackbar.Add(result.Message ?? "Error", Severity.Error);
        _loading = false;
    }

    private static Color StatusColor(string status) => status switch
    {
        "Delivered" => Color.Success,
        "InTransit" => Color.Info,
        "Pending" => Color.Warning,
        "Cancelled" => Color.Error,
        _ => Color.Default,
    };

    private bool Filter(DeliveryOrderDto d)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var s = _search.Trim();
        return d.PONumber.Contains(s, StringComparison.OrdinalIgnoreCase)
            || (d.Product?.ProductName?.Contains(s, StringComparison.OrdinalIgnoreCase) ?? false);
    }
}
