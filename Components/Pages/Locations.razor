@page "/locations"
@inherits LocalizedComponentBase
@inject LocationService LocationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@L["locations.title"] - StockDemo Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@L["locations.title"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">
        @L["locations.add"]
    </MudButton>
</div>

<MudPaper Elevation="1">
    <MudTable Items="_locations" Loading="_loading" Hover="true" Striped="true" Filter="Filter">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="@L["common.search"]" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["locations.code"]</MudTh>
            <MudTh>@L["locations.name"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh Style="text-align:center">@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["locations.code"]">@context.LocationCode</MudTd>
            <MudTd DataLabel="@L["locations.name"]">@context.LocationName</MudTd>
            <MudTd DataLabel="@L["common.status"]">
                @if (context.IsActive)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">@L["common.active"]</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">@L["common.inactive"]</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L["common.actions"]" Style="text-align:center">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                               OnClick="() => OpenEditAsync(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="() => DeleteAsync(context)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText Class="pa-4">@L["locations.none"]</MudText></NoRecordsContent>
        <PagerContent><MudTablePager RowsPerPageString="@L["common.rowsPerPage"]" /></PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<LocationDto> _locations = new();
    private string _search = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await LocationService.GetAllAsync();
        if (result.Success) _locations = result.Data ?? new();
        else Snackbar.Add(result.Message ?? "Error", Severity.Error);
        _loading = false;
    }

    private bool Filter(LocationDto l)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var s = _search.Trim();
        return l.LocationCode.Contains(s, StringComparison.OrdinalIgnoreCase)
            || l.LocationName.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<Dialogs.LocationDialog>(L["locations.add"]);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }

    private async Task OpenEditAsync(LocationDto location)
    {
        var parameters = new DialogParameters<Dialogs.LocationDialog> { { x => x.Existing, location } };
        var dialog = await DialogService.ShowAsync<Dialogs.LocationDialog>(L["locations.edit"], parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }

    private async Task DeleteAsync(LocationDto location)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            L["common.confirmDeleteTitle"],
            $"{L["locations.confirmDelete"]} — {location.LocationName}",
            yesText: L["common.delete"], cancelText: L["common.cancel"]);

        if (confirm == true)
        {
            var result = await LocationService.DeleteAsync(location.LocationId);
            if (result.Success)
            {
                Snackbar.Add(L["common.delete"], Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Error", Severity.Error);
            }
        }
    }
}
