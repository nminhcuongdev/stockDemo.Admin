@page "/products"
@inherits LocalizedComponentBase
@inject ProductService ProductService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@L["products.title"] - StockDemo Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@L["products.title"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateAsync">
        @L["products.add"]
    </MudButton>
</div>

<MudPaper Elevation="1">
    <MudTable Items="_products" Loading="_loading" Hover="true" Striped="true"
              Filter="Filter" @bind-SelectedItem="_selected">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="@L["common.search"]" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["products.codeShort"]</MudTh>
            <MudTh>@L["products.name"]</MudTh>
            <MudTh>@L["products.unitShort"]</MudTh>
            <MudTh Style="text-align:right">@L["products.minShort"]</MudTh>
            <MudTh Style="text-align:right">@L["products.maxShort"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh Style="text-align:center">@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["products.codeShort"]">@context.ProductCode</MudTd>
            <MudTd DataLabel="@L["products.name"]">@context.ProductName</MudTd>
            <MudTd DataLabel="@L["products.unitShort"]">@context.Unit</MudTd>
            <MudTd DataLabel="@L["products.minShort"]" Style="text-align:right">@context.MinQuantity</MudTd>
            <MudTd DataLabel="@L["products.maxShort"]" Style="text-align:right">@(context.MaxQuantity?.ToString() ?? "-")</MudTd>
            <MudTd DataLabel="@L["common.status"]">
                @if (context.IsActive)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">@L["common.active"]</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">@L["common.inactive"]</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L["common.actions"]" Style="text-align:center">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                               OnClick="() => OpenEditAsync(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="() => DeleteAsync(context)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">@L["products.none"]</MudText>
        </NoRecordsContent>
        <LoadingContent>
            <MudText Class="pa-4">@L["common.loading"]</MudText>
        </LoadingContent>
        <PagerContent>
            <MudTablePager RowsPerPageString="@L["common.rowsPerPage"]" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<ProductDto> _products = new();
    private ProductDto? _selected;
    private string _search = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await ProductService.GetAllAsync();
        if (result.Success)
        {
            _products = result.Data ?? new();
        }
        else
        {
            Snackbar.Add(result.Message ?? "Error", Severity.Error);
        }
        _loading = false;
    }

    private bool Filter(ProductDto p)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var s = _search.Trim();
        return p.ProductCode.Contains(s, StringComparison.OrdinalIgnoreCase)
            || p.ProductName.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<Dialogs.ProductDialog>(L["products.add"]);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }

    private async Task OpenEditAsync(ProductDto product)
    {
        var parameters = new DialogParameters<Dialogs.ProductDialog> { { x => x.Existing, product } };
        var dialog = await DialogService.ShowAsync<Dialogs.ProductDialog>(L["products.edit"], parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }

    private async Task DeleteAsync(ProductDto product)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            L["common.confirmDeleteTitle"],
            $"{L["products.confirmDelete"]} — {product.ProductName}",
            yesText: L["common.delete"], cancelText: L["common.cancel"]);

        if (confirm == true)
        {
            var result = await ProductService.DeleteAsync(product.ProductId);
            if (result.Success)
            {
                Snackbar.Add(L["common.delete"], Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Error", Severity.Error);
            }
        }
    }
}
