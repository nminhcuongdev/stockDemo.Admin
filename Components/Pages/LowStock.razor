@page "/low-stock"
@inject DashboardService DashboardService
@inject ISnackbar Snackbar

<PageTitle>Cảnh báo tồn thấp - StockDemo Admin</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Cảnh báo tồn thấp</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">
    Danh sách sản phẩm có tổng tồn kho dưới định mức tối thiểu.
</MudText>

<MudPaper Elevation="1">
    <MudTable Items="_items" Loading="_loading" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>Mã SP</MudTh>
            <MudTh>Tên sản phẩm</MudTh>
            <MudTh>Đơn vị</MudTh>
            <MudTh Style="text-align:right">Tồn hiện tại</MudTh>
            <MudTh Style="text-align:right">Định mức tối thiểu</MudTh>
            <MudTh Style="text-align:right">Thiếu hụt</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Mã SP">@context.Product?.ProductCode</MudTd>
            <MudTd DataLabel="Tên sản phẩm">@context.Product?.ProductName</MudTd>
            <MudTd DataLabel="Đơn vị">@context.Product?.Unit</MudTd>
            <MudTd DataLabel="Tồn hiện tại" Style="text-align:right">@context.CurrentQuantity</MudTd>
            <MudTd DataLabel="Định mức tối thiểu" Style="text-align:right">@context.MinQuantity</MudTd>
            <MudTd DataLabel="Thiếu hụt" Style="text-align:right">
                <MudChip T="string" Color="Color.Error" Size="Size.Small">@context.Shortage</MudChip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Class="pa-4">Không có sản phẩm nào dưới định mức. 🎉</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<LowStockItemDto> _items = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var result = await DashboardService.GetLowStockAsync();
        if (result.Success)
        {
            _items = result.Data ?? new();
        }
        else
        {
            Snackbar.Add(result.Message ?? "Không tải được cảnh báo tồn thấp", Severity.Error);
        }
        _loading = false;
    }
}
