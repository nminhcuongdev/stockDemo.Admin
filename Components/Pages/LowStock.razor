@page "/low-stock"
@inherits LocalizedComponentBase
@inject DashboardService DashboardService
@inject ISnackbar Snackbar

<PageTitle>@L["lowStock.title"] - StockDemo Admin</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["lowStock.title"]</MudText>
<MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">@L["lowStock.subtitle"]</MudText>

<MudPaper Elevation="1">
    <MudTable Items="_items" Loading="_loading" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>@L["products.codeShort"]</MudTh>
            <MudTh>@L["products.name"]</MudTh>
            <MudTh>@L["products.unitShort"]</MudTh>
            <MudTh Style="text-align:right">@L["lowStock.current"]</MudTh>
            <MudTh Style="text-align:right">@L["lowStock.min"]</MudTh>
            <MudTh Style="text-align:right">@L["lowStock.shortage"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["products.codeShort"]">@context.Product?.ProductCode</MudTd>
            <MudTd DataLabel="@L["products.name"]">@context.Product?.ProductName</MudTd>
            <MudTd DataLabel="@L["products.unitShort"]">@context.Product?.Unit</MudTd>
            <MudTd DataLabel="@L["lowStock.current"]" Style="text-align:right">@context.CurrentQuantity</MudTd>
            <MudTd DataLabel="@L["lowStock.min"]" Style="text-align:right">@context.MinQuantity</MudTd>
            <MudTd DataLabel="@L["lowStock.shortage"]" Style="text-align:right">
                <MudChip T="string" Color="Color.Error" Size="Size.Small">@context.Shortage</MudChip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText Class="pa-4">@L["dashboard.noLowStock"]</MudText></NoRecordsContent>
        <PagerContent><MudTablePager RowsPerPageString="@L["common.rowsPerPage"]" /></PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<LowStockItemDto> _items = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var result = await DashboardService.GetLowStockAsync();
        if (result.Success) _items = result.Data ?? new();
        else Snackbar.Add(result.Message ?? "Error", Severity.Error);
        _loading = false;
    }
}
