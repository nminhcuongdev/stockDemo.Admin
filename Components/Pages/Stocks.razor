@page "/stocks"
@inherits LocalizedComponentBase
@inject StockService StockService
@inject ISnackbar Snackbar

<PageTitle>@L["stocks.title"] - StockDemo Admin</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@L["stocks.title"]</MudText>

<MudPaper Elevation="1">
    <MudTable Items="_stocks" Loading="_loading" Hover="true" Striped="true" Filter="Filter">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="@L["stocks.searchHint"]" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["common.product"]</MudTh>
            <MudTh>@L["common.location"]</MudTh>
            <MudTh Style="text-align:right">@L["common.quantity"]</MudTh>
            <MudTh>@L["stocks.qrCode"]</MudTh>
            <MudTh>@L["stocks.lastUpdated"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["common.product"]">
                <MudText Typo="Typo.body2">@(context.Product?.ProductName ?? $"#{context.ProductId}")</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary">@context.Product?.ProductCode</MudText>
            </MudTd>
            <MudTd DataLabel="@L["common.location"]">@(context.Location?.LocationName ?? $"#{context.LocationId}")</MudTd>
            <MudTd DataLabel="@L["common.quantity"]" Style="text-align:right">
                <MudText Typo="Typo.body1"><b>@context.Quantity</b></MudText>
            </MudTd>
            <MudTd DataLabel="@L["stocks.qrCode"]">@context.QRCode</MudTd>
            <MudTd DataLabel="@L["stocks.lastUpdated"]">@context.LastUpdated.ToString("dd/MM/yyyy HH:mm")</MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText Class="pa-4">@L["stocks.none"]</MudText></NoRecordsContent>
        <PagerContent><MudTablePager RowsPerPageString="@L["common.rowsPerPage"]" /></PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<StockDto> _stocks = new();
    private string _search = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        var result = await StockService.GetAllAsync();
        if (result.Success) _stocks = result.Data ?? new();
        else Snackbar.Add(result.Message ?? "Error", Severity.Error);
        _loading = false;
    }

    private bool Filter(StockDto s)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var q = _search.Trim();
        return (s.Product?.ProductName?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.Product?.ProductCode?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.Location?.LocationName?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false)
            || (s.QRCode?.Contains(q, StringComparison.OrdinalIgnoreCase) ?? false);
    }
}
