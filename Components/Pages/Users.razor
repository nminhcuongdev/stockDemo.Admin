@page "/users"
@inherits LocalizedComponentBase
@inject UserService UserService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>@L["users.title"] - StockDemo Admin</PageTitle>

<div class="d-flex justify-space-between align-center mb-4">
    <MudText Typo="Typo.h4">@L["users.title"]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.PersonAdd" OnClick="OpenCreateAsync">
        @L["users.add"]
    </MudButton>
</div>

<MudPaper Elevation="1">
    <MudTable Items="_users" Loading="_loading" Hover="true" Striped="true" Filter="Filter">
        <ToolBarContent>
            <MudTextField @bind-Value="_search" Placeholder="@L["common.search"]" Immediate="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["users.username"]</MudTh>
            <MudTh>@L["users.fullName"]</MudTh>
            <MudTh>@L["users.role"]</MudTh>
            <MudTh>@L["common.status"]</MudTh>
            <MudTh>@L["users.lastLogin"]</MudTh>
            <MudTh Style="text-align:center">@L["common.actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@L["users.username"]">@context.Username</MudTd>
            <MudTd DataLabel="@L["users.fullName"]">@context.FullName</MudTd>
            <MudTd DataLabel="@L["users.role"]">
                <MudChip T="string" Size="Size.Small" Color="@RoleColor(context.Role)">@context.Role</MudChip>
            </MudTd>
            <MudTd DataLabel="@L["common.status"]">
                @if (context.IsActive)
                {
                    <MudChip T="string" Color="Color.Success" Size="Size.Small">@L["common.active"]</MudChip>
                }
                else
                {
                    <MudChip T="string" Color="Color.Default" Size="Size.Small">@L["common.inactive"]</MudChip>
                }
            </MudTd>
            <MudTd DataLabel="@L["users.lastLogin"]">
                @(context.LastLoginDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")
            </MudTd>
            <MudTd DataLabel="@L["common.actions"]" Style="text-align:center">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                               OnClick="() => OpenEditAsync(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="() => DeleteAsync(context)" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText Class="pa-4">@L["users.none"]</MudText></NoRecordsContent>
        <PagerContent><MudTablePager RowsPerPageString="@L["common.rowsPerPage"]" /></PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<UserDto> _users = new();
    private string _search = string.Empty;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await UserService.GetAllAsync();
        if (result.Success) _users = result.Data ?? new();
        else Snackbar.Add(result.Message ?? "Error", Severity.Error);
        _loading = false;
    }

    private static Color RoleColor(string role) => role switch
    {
        "Admin" => Color.Error,
        "Manager" => Color.Warning,
        _ => Color.Info,
    };

    private bool Filter(UserDto u)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var s = _search.Trim();
        return u.Username.Contains(s, StringComparison.OrdinalIgnoreCase)
            || u.FullName.Contains(s, StringComparison.OrdinalIgnoreCase)
            || u.Role.Contains(s, StringComparison.OrdinalIgnoreCase);
    }

    private async Task OpenCreateAsync()
    {
        var dialog = await DialogService.ShowAsync<Dialogs.UserDialog>(L["users.add"]);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }

    private async Task OpenEditAsync(UserDto user)
    {
        var parameters = new DialogParameters<Dialogs.UserDialog> { { x => x.Existing, user } };
        var dialog = await DialogService.ShowAsync<Dialogs.UserDialog>(L["users.edit"], parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled) await LoadAsync();
    }

    private async Task DeleteAsync(UserDto user)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            L["common.confirmDeleteTitle"],
            $"{L["users.confirmDelete"]} — {user.Username}",
            yesText: L["common.delete"], cancelText: L["common.cancel"]);

        if (confirm == true)
        {
            var result = await UserService.DeleteAsync(user.UserId);
            if (result.Success)
            {
                Snackbar.Add(L["common.delete"], Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(result.Message ?? "Error", Severity.Error);
            }
        }
    }
}
