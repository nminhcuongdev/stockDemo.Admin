<MudPaper Class="pa-4 d-flex align-center" Elevation="2" Style="height: 100%;">
    <MudIcon Icon="@Icon" Color="Color" Size="Size.Large" Class="mr-4" />
    <div>
        <MudText Typo="Typo.body2" Class="mud-text-secondary">@Title</MudText>
        <MudText Typo="Typo.h5">@Value</MudText>
    </div>
</MudPaper>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public string Icon { get; set; } = Icons.Material.Filled.Info;
    [Parameter] public Color Color { get; set; } = Color.Primary;
}
