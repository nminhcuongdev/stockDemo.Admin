@inject LocationService LocationService
@inject ISnackbar Snackbar
@inject LocalizationService L

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.LocationCode" Label="@L["locations.code"]"
                          Required="true" Disabled="IsEdit" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.LocationName" Label="@L["locations.name"]"
                          Required="true" Variant="Variant.Outlined" Class="mb-3" />
            @if (IsEdit)
            {
                <MudSwitch @bind-Value="_isActive" Label="@L["common.active"]" Color="Color.Primary" />
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["common.save"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public LocationDto? Existing { get; set; }

    private MudForm _form = default!;
    private CreateLocationDto _model = new();
    private bool _isActive = true;
    private bool _saving;

    private bool IsEdit => Existing is not null;

    protected override void OnInitialized()
    {
        if (Existing is not null)
        {
            _model = new CreateLocationDto
            {
                LocationCode = Existing.LocationCode,
                LocationName = Existing.LocationName,
            };
            _isActive = Existing.IsActive;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;

        if (IsEdit)
        {
            var update = new UpdateLocationDto
            {
                LocationName = _model.LocationName,
                IsActive = _isActive,
            };
            var result = await LocationService.UpdateAsync(Existing!.LocationId, update);
            _saving = false;
            if (result.Success)
            {
                Snackbar.Add("Cập nhật vị trí thành công", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(result.Message ?? "Cập nhật thất bại", Severity.Error);
            }
        }
        else
        {
            var result = await LocationService.CreateAsync(_model);
            _saving = false;
            if (result.Success)
            {
                Snackbar.Add("Thêm vị trí thành công", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(result.Message ?? "Thêm vị trí thất bại", Severity.Error);
            }
        }
    }
}
