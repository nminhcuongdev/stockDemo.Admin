@inject ProductService ProductService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.ProductCode" Label="Mã sản phẩm"
                          Required="true" RequiredError="Mã sản phẩm là bắt buộc"
                          Disabled="IsEdit" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.ProductName" Label="Tên sản phẩm"
                          Required="true" RequiredError="Tên sản phẩm là bắt buộc"
                          Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.Description" Label="Mô tả"
                          Lines="2" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.Unit" Label="Đơn vị tính"
                          Required="true" RequiredError="Đơn vị tính là bắt buộc"
                          Variant="Variant.Outlined" Class="mb-3" />
            <MudGrid>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="_model.MinQuantity" Label="Định mức tối thiểu"
                                     Min="0" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="_model.MaxQuantity" Label="Định mức tối đa"
                                     Min="0" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            @if (IsEdit)
            {
                <MudSwitch @bind-Value="_isActive" Label="Đang hoạt động" Color="Color.Primary" Class="mt-3" />
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Hủy</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync" Disabled="_saving">
            @(_saving ? "Đang lưu..." : "Lưu")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>When set, the dialog edits this product; otherwise it creates a new one.</summary>
    [Parameter] public ProductDto? Existing { get; set; }

    private MudForm _form = default!;
    private CreateProductDto _model = new();
    private bool _isActive = true;
    private bool _saving;

    private bool IsEdit => Existing is not null;

    protected override void OnInitialized()
    {
        if (Existing is not null)
        {
            _model = new CreateProductDto
            {
                ProductCode = Existing.ProductCode,
                ProductName = Existing.ProductName,
                Description = Existing.Description,
                Unit = Existing.Unit,
                MinQuantity = Existing.MinQuantity,
                MaxQuantity = Existing.MaxQuantity,
            };
            _isActive = Existing.IsActive;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        // The API's DTOs use non-nullable strings, so send "" (never null) for optional text.
        _model.Description ??= string.Empty;

        _saving = true;

        if (IsEdit)
        {
            var update = new UpdateProductDto
            {
                ProductName = _model.ProductName,
                Description = _model.Description,
                Unit = _model.Unit,
                MinQuantity = _model.MinQuantity,
                MaxQuantity = _model.MaxQuantity,
                IsActive = _isActive,
            };
            var result = await ProductService.UpdateAsync(Existing!.ProductId, update);
            _saving = false;
            if (result.Success)
            {
                Snackbar.Add("Cập nhật sản phẩm thành công", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(result.Message ?? "Cập nhật thất bại", Severity.Error);
            }
        }
        else
        {
            var result = await ProductService.CreateAsync(_model);
            _saving = false;
            if (result.Success)
            {
                Snackbar.Add("Thêm sản phẩm thành công", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(result.Message ?? "Thêm sản phẩm thất bại", Severity.Error);
            }
        }
    }
}
