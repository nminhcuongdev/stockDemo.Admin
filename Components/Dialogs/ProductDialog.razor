@inject ProductService ProductService
@inject ISnackbar Snackbar
@inject LocalizationService L

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_model">
            <MudTextField @bind-Value="_model.ProductCode" Label="@L["products.code"]"
                          Required="true" Disabled="IsEdit" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.ProductName" Label="@L["products.name"]"
                          Required="true" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.Description" Label="@L["products.description"]"
                          Lines="2" Variant="Variant.Outlined" Class="mb-3" />
            <MudTextField @bind-Value="_model.Unit" Label="@L["products.unit"]"
                          Required="true" Variant="Variant.Outlined" Class="mb-3" />
            <MudGrid>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="_model.MinQuantity" Label="@L["products.minQty"]"
                                     Min="0" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudNumericField @bind-Value="_model.MaxQuantity" Label="@L["products.maxQty"]"
                                     Min="0" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>
            @if (IsEdit)
            {
                <MudSwitch @bind-Value="_isActive" Label="@L["common.active"]" Color="Color.Primary" Class="mt-3" />
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@L["common.cancel"]</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SubmitAsync" Disabled="_saving">
            @(_saving ? L["common.saving"] : L["common.save"])
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;

    /// <summary>When set, the dialog edits this product; otherwise it creates a new one.</summary>
    [Parameter] public ProductDto? Existing { get; set; }

    private MudForm _form = default!;
    private CreateProductDto _model = new();
    private bool _isActive = true;
    private bool _saving;

    private bool IsEdit => Existing is not null;

    protected override void OnInitialized()
    {
        if (Existing is not null)
        {
            _model = new CreateProductDto
            {
                ProductCode = Existing.ProductCode,
                ProductName = Existing.ProductName,
                Description = Existing.Description,
                Unit = Existing.Unit,
                MinQuantity = Existing.MinQuantity,
                MaxQuantity = Existing.MaxQuantity,
            };
            _isActive = Existing.IsActive;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        // The API's DTOs use non-nullable strings, so send "" (never null) for optional text.
        _model.Description ??= string.Empty;

        _saving = true;

        if (IsEdit)
        {
            var update = new UpdateProductDto
            {
                ProductName = _model.ProductName,
                Description = _model.Description,
                Unit = _model.Unit,
                MinQuantity = _model.MinQuantity,
                MaxQuantity = _model.MaxQuantity,
                IsActive = _isActive,
            };
            var result = await ProductService.UpdateAsync(Existing!.ProductId, update);
            _saving = false;
            if (result.Success)
            {
                Snackbar.Add("Cập nhật sản phẩm thành công", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(result.Message ?? "Cập nhật thất bại", Severity.Error);
            }
        }
        else
        {
            var result = await ProductService.CreateAsync(_model);
            _saving = false;
            if (result.Success)
            {
                Snackbar.Add("Thêm sản phẩm thành công", Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add(result.Message ?? "Thêm sản phẩm thất bại", Severity.Error);
            }
        }
    }
}
